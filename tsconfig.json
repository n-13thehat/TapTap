{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./app/*",
        "./*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/providers/*": [
        "./providers/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/stores/*": [
        "./stores/*"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/visuals/*": [
        "./visuals/*"
      ],
      "@/electron/*": [
        "./electron/*"
      ]
    },
    "target": "ES2021",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": false
  },
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "mobile",
    "cramgram",
    "docker-build-temp",
    ".next",
    "dist",
    "out",
    "tests",
    "**/*.test.ts",
    "**/*.test.tsx",
    "lib/collaboration/**",
    "lib/performance/**",
    "lib/security/**",
    "lib/library/libraryManager.ts",
    "lib/components/optimized/**",
    "lib/errors/ErrorBoundary.tsx",
    "lib/hooks/useErrorHandling.ts",
    "lib/hooks/useOptimizedCallback.ts",
    "lib/persistence/migration.ts",
    "lib/utils/performance.ts",
    "lib/utils/type-guards.ts",
    "lib/store.tsx",
    "components/collaboration/**",
    "components/performance/**",
    "components/security/**",
    "components/player/AdvancedQueue.tsx",
    "components/player/EnhancedGlobalPlayer.tsx",
    "components/player/SocialPlayer.tsx",
    "components/library/LibraryGrid.tsx",
    "components/library/LibraryInterface.tsx",
    "providers/QueuePersistenceProvider.tsx",
    "hooks/useLibrary.ts",
    "hooks/usePerformance.ts",
    "stores/enhancedPlayer.ts",
    "app/library/page.refactored.tsx"
  ]
}
